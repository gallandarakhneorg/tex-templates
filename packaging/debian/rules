	install -m 0644 "$(build_src)/presentations/ciad-2025/"ciadbeamer-documentation.pdf "$(install_dir)/$(beamer_doc_target)/ciad"
	install -m 0644 "$(build_src)/presentations/ciad-2025/docfigs/"* "$(install_dir)/$(beamer_doc_target)/ciad/docfigs"
