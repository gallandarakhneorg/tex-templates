	install -d -m 0755 "$(install_dir)/$(doc_install_target)/spim/spimubephdthesis"
	install -m 644 "$(build_src)/spim/ube/spimubephdthesis/"spimubephdthesis_ex* "$(install_dir)/$(doc_install_target)/spim/spimubephdthesis/"
	#
	#
	# UBE HDR
	#
