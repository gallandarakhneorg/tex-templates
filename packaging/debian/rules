	install -m 644 "$(build_src)/spim/ube/spimubehdrapplication/"*.bib "$(install_dir)/$(doc_install_target)/spim/spimubehdrapplication/"
	install -m 644 "$(build_src)/spim/ube/spimubehdrapplication/diplomes/"* "$(install_dir)/$(doc_install_target)/spim/spimubehdrapplication/diplomes/"
