	install -m 644 "$(build_src)/spim/umlp/spimumlpphdthesis/"*.cfg "$(install_dir)/$(tex_install_target)/spim/spimumlpphdthesis/"
	install -m 644 "$(build_src)/spim/umlp/spimumlpphdthesis/spimumlpphdthesis_umlplogo.pdf" "$(install_dir)/$(tex_install_target)/spim/spimumlpphdthesis/"
	install -m 644 "$(build_src)/spim/umlp/spimumlpphdthesis/spimumlpphdthesis_femtost.pdf" "$(install_dir)/$(tex_install_target)/spim/spimumlpphdthesis/"
	#
	install -d -m 0755 "$(install_dir)/$(doc_install_target)/spim/spimumlpphdthesis"
	install -m 644 "$(build_src)/spim/umlp/spimumlpphdthesis/"spimumlpphdthesis_ex* "$(install_dir)/$(doc_install_target)/spim/spimumlpphdthesis/"
