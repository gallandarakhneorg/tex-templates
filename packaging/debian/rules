	install -m 0644 "$(build_src)/presentations/ciad-2025/"ciad-*-background-*.pdf "$(install_dir)/$(beamer_install_target)/outer"
	install -m 0644 "$(build_src)/presentations/ciad-2025/"ciad-title-hands.png "$(install_dir)/$(beamer_install_target)/outer"
