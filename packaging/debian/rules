# Rule to extract tarball (idempotent)
$(EXTRACT_DIR)/.extracted:
	mkdir -p "$(EXTRACT_DIR)"
	tar xfz "$(TARBALL)" -C "$(EXTRACT_DIR)" --strip-components=1
	touch $@

# Clean up extracted directory
override_dh_clean:
	dh_clean
	rm -rf "$(EXTRACT_DIR)"
