	install -m 0644 "$(build_src)/reports/utbmciad-2019/"*logo.pdf "$(install_dir)/$(tex_install_target)/reports/utbmciad-2019/"
	install -m 0644 "$(build_src)/reports/utbmciad-2019/utbmciad-frontbackground.pdf" "$(install_dir)/$(tex_install_target)/reports/utbmciad-2019/"
