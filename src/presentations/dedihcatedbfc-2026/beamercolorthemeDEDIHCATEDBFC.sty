\ProvidesPackage{beamercolorthemeDEDIHCATEDBFC}[2026/04/20]

\mode<presentation>

\definecolor{DEDIHCATEDdarkblue}{RGB}{1,35,35}
\definecolor{DEDIHCATEDblue}{RGB}{8,120,158}
\definecolor{DEDIHCATEDlightblue}{RGB}{151,211,195}
\definecolor{DEDIHCATEDmorelightblue}{RGB}{229,255,248}

\definecolor{EDIHyellow}{RGB}{253,208,23}

\setbeamercolor{normal text}{fg=black}
\setbeamercolor{alternate normal text}{fg=white}
\setbeamercolor{example text}{fg=DEDIHCATEDdarkblue}
\setbeamercolorXXX{emphased text}{fg=DEDIHCATEDblue}
\setbeamercolorXXX{alternate emphased text}{fg=DEDIHCATEDlightblue}
\setbeamercolor{emphased emphased text}{fg=DEDIHCATEDlightblue}
\setbeamercolor{alternate emphased emphased text}{fg=DEDIHCATEDlightblue}
\setbeamercolor{alerted text}{fg=EDIHyellow}
\setbeamercolor{verse}{fg=DEDIHCATEDdarkblue}
\setbeamercolor{quotation}{fg=DEDIHCATEDdarkblue}
\setbeamercolor{quote}{fg=DEDIHCATEDdarkblue}
\setbeamercolor{semiverbatim}{fg=darkgray}
\setbeamercolor{structure}{fg=DEDIHCATEDdarkblue}
\setbeamercolor{item projected}{fg=white,bg=DEDIHCATEDdarkblue}
\setbeamercolor{background canvas}{bg=white}
\setbeamercolor{author}{fg=DEDIHCATEDblue}
\setbeamercolor{author in head/foot}{fg=darkgray}
\setbeamercolor{title in head/foot}{fg=darkgray}
\setbeamercolor{date in head/foot}{fg=darkgray}
\setbeamercolor{text in small title area}{fg=black}
\setbeamercolor{text in big title area}{fg=white}
\setbeamercolor{institute}{fg=darkgray}
\setbeamercolor{date}{fg=darkgray}
\setbeamercolorXXX{frametitle}{fg=DEDIHCATEDblue,bg=white}
\setbeamercolor{framesubtitle}{fg=DEDIHCATEDblue}
\setbeamercolor{frametitle fancy words}{fg=DEDIHCATEDblue}
\setbeamercolor{maintitle}{fg=black}
\setbeamercolor{maintitle fancy letter}{fg=black}
\setbeamercolorXXX{righttitle}{fg=white}
\setbeamercolor{normal text in righttitle}{fg=white}
\setbeamercolorXXX{lawn}{bg=DEDIHCATEDblue,fg=white}
\setbeamercolorXXX{textpicture}{bg=DEDIHCATEDblue,fg=red}
\setbeamercolorXXX{textvideo}{bg=DEDIHCATEDblue,fg=white}
\setbeamercolorXXX{icon grid}{fg=white}
\setbeamercolorXXX{library slide}{bg=lightgray,fg=black}
\setbeamercolor{part title}{fg=white}
\setbeamercolor{part title fancy letter}{fg=DEDIHCATEDblue}
\setbeamercolor{footnote}{fg=darkgray}
\setbeamercolor{sidenote}{fg=DEDIHCATEDblue}
\setbeamercolor{button}{bg=DEDIHCATEDblue,fg=white}
\setbeamercolor{description item}{fg=EDIHyellow}
\setbeamercolor{alternate description item}{fg=EDIHyellow}
\setbeamercolorXXX{block title}{fg=white,bg=DEDIHCATEDblue}
\setbeamercolorXXX{block body}{fg=black,bg=DEDIHCATEDmorelightblue}
\setbeamercolor{block title alerted}{fg=white,bg=EDIHyellow}
\setbeamercolor{block body alerted}{fg=DEDIHCATEDdarkblue,bg=EDIHyellow}
\setbeamercolor{block body remark}{fg=black,bg=lightgray}
\setbeamercolorXXX{block body alerted emphased text}{fg=EDIHyellow}
\setbeamercolor{block body alerted alerted text}{fg=red}
\setbeamercolor{block body remark emphased text}{fg=DEDIHCATEDdarkblue}
\setbeamercolor{block body remark alerted text}{fg=EDIHyellow}
\setbeamercolor{block title example}{fg=black,bg=lightgray}
\setbeamercolorXXX{block title definition}{parent=block title,fg=DEDIHCATEDlightblue}
\setbeamercolorXXX{block body definition}{parent=block body}


\setbeamercolorXXX{title in left anchor block}{parent=normal text}
\setbeamercolorXXX{title in right anchor block}{parent=normal text}
\setbeamercolorXXX{circled text in left anchor block}{fg=DEDIHCATEDblue}
\setbeamercolorXXX{circled text in right anchor block}{fg=black}
\setbeamercolorXXX{line in left anchor block}{fg=black, bg=black}
\setbeamercolorXXX{line in right anchor block}{fg=black, bg=white}

% Current sections
\setbeamercolor{section in toc}{fg=white}
\setbeamercolor{subsection in toc}{fg=white}
\setbeamercolor{subsubsection in toc}{fg=white}
% Other sections
\setbeamercolor{section in toc shaded}{fg=black}
\setbeamercolor{subsection in toc shaded}{fg=black}
\setbeamercolor{subsubsection in toc shaded}{fg=black}
% Section number in the squares
\setbeamercolor{section number projected}{fg=white}

\setbeamercolorXXX{footline}{bg=white,fg=DEDIHCATEDlightblue}

\setbeamercolorXXX{circle progress bar}{bg=footline.bg,fg=darkgray}
\setbeamercolorXXX{circle progress bar/first bar}{bg=DEDIHCATEDblue}
\setbeamercolorXXX{circle progress bar/second bar}{bg=EDIHyellow}
\setbeamercolorXXX{circle progress bar/third bar}{bg=footline.bg}

\setbeamercolorXXX{plain frametitle}{fg=DEDIHCATEDblue}
\setbeamercolorXXX{plain framesubtitle}{fg=DEDIHCATEDlightblue}
\setbeamercolorXXX{plain frametitle fancy words}{fg=DEDIHCATEDlightblue}

\setbeamercolorXXX{code keyword}{fg=DEDIHCATEDblue}
\setbeamercolorXXX{code string}{fg=EDIHyellow}
\setbeamercolorXXX{code comment}{fg=DEDIHCATEDlightblue}

\setbeamercolorXXX{table header}{fg=DEDIHCATEDlightblue,bg=black}
\setbeamercolorXXX{table rules}{fg=black}
\setbeamercolorXXX{table content}{fg=black,bg=white}

\setbeamercolorXXX{top background in toc}{bg=frametitle.bg}
\setbeamercolorXXX{bottom background in toc}{bg=footline.bg}

\setbeamercolorXXX{fancy box}{bg=black, fg=DEDIHCATEDmorelightblue}
\setbeamercolorXXX{title in fancy box}{fg=DEDIHCATEDblue}
\setbeamercolorXXX{corner in fancy box}{fg=white, bg=DEDIHCATEDblue}
\setbeamercolorXXX{emphased text in fancy box}{fg=DEDIHCATEDlightblue}
\setbeamercolorXXX{emphased emphased text in fancy box}{fg=EDIHyellow}

\setbeamercolor{simple block}{fg=white,bg=black}
\setbeamercolor{emphazed simple block}{fg=emphased text in fancy box.fg}
\setbeamercolor{emphazed emphazed simple block}{fg=emphased emphased text in fancy box.fg}
\setbeamercolor{alerted simple block}{fg=EDIHyellow}

\setbeamercolorXXX{right arrow sequence}{fg=white,bg=DEDIHCATEDdarkblue}

\setbeamercolorXXX{bottom arrow sequence}{fg=white,bg=DEDIHCATEDdarkblue}

\setbeamercolor{text in conference presentation title area}{fg=black}
\setbeamercolor{text in conference presentation author area}{fg=DEDIHCATEDlightblue}
\setbeamercolor{text in conference presentation date and place area}{fg=white}
\setbeamercolor{text in conference presentation conference area}{fg=white}

\mode<all>

